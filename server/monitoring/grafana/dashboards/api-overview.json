      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "title": "Go GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{job=\"xoberon-api\"}[5m])",
          "legendFormat": "GC Pause Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
