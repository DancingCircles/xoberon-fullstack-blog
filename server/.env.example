# ============================================================
# XOBERON Server 环境变量配置
# 复制为 .env 并修改实际值
# ============================================================

# ============================================================
# 服务器配置
# ============================================================
SERVER_PORT=8080
# Metrics 绑定地址（Docker 环境用 0.0.0.0 允许 Prometheus 容器抓取）
SERVER_METRICS_ADDR=0.0.0.0
GIN_MODE=release
# 信任代理（Nginx 容器 IP，Docker bridge 网络默认网段）
SERVER_TRUSTED_PROXIES=172.16.0.0/12

# ============================================================
# 数据库（生产环境必须使用强密码 + SSL）
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=xoberon
DB_PASSWORD=          # 至少 32 字符，包含大小写+数字+特殊字符，生成: openssl rand -base64 24
DB_NAME=xoberon
DB_SSLMODE=require    # 生产环境必须 require
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# ============================================================
# Redis（生产环境必须设置密码）
# ============================================================
REDIS_ADDR=redis:6379
REDIS_PASSWORD=       # 至少 32 字符随机字符串，生成: openssl rand -base64 24
REDIS_DB=0

# ============================================================
# JWT（生产环境必须使用强密钥）
# ============================================================
JWT_SECRET=           # 至少 64 字符随机字符串，生成: openssl rand -hex 32
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# ============================================================
# CORS（生产环境必须限制为实际域名）
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# ============================================================
# 内容审核（可选）
# ============================================================
MODERATION_ENABLED=true
MODERATION_TIMEOUT=10s
MODERATION_WORKER_ENABLED=true
MODERATION_WORKER_INTERVAL=5m

# ============================================================
# 通义千问（内容审核 Worker）
# ============================================================
QWEN_API_KEY=         # 通义千问 API Key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# ============================================================
# 日志（生产环境使用 JSON 格式 + info 级别）
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# Grafana（监控仪表盘）
# ============================================================
GRAFANA_PASSWORD=     # Grafana admin 密码，生成: openssl rand -base64 16
